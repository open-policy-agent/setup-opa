    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.58.2",
    "esbuild": "^0.28.0",
